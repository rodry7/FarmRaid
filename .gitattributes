# Normalize all text files to LF so shell scripts and Python files
# are not corrupted by Windows CRLF conversion when built into Linux containers.
* text=auto eol=lf

# Explicitly enforce LF for files that must be LF on Linux
*.sh   text eol=lf
*.py   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.txt  text eol=lf
*.jsx  text eol=lf
*.js   text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.conf text eol=lf
*.ini  text eol=lf
*.toml text eol=lf
*.env* text eol=lf

# Binary — never touch line endings
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.pyc  binary
*.pyo  binary
